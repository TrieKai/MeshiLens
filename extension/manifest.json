{
  "manifest_version": 3,
  "name": "MeshiLens — Tabelog for Maps",
  "version": "0.3.7",
  "description": "在 Google Maps 店家頁顯示 Tabelog 評分、預約、付款方式與百名店資訊。",
  "minimum_chrome_version": "109",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://meshilens.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.co.jp/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["category.js", "maps.js", "settings.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MeshiLens",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
