# Leave empty until a browser client is introduced. Use one exact HTTPS origin then.
MESHI_ALLOWED_ORIGIN=
# Optional: enables the review-free AI dining advice card on /advice.
# Keep this server-side only; never expose it in the browser extension.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# --- Persistent result cache (match / michelin / advice) ---
# Priority: Upstash REST → Redis URL → local file cache (+ always memory L1).
# TTL: match 6h, Michelin 24h, advice 30d (same as before).

# Vercel Upstash Marketplace (recommended; populated automatically after linking).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Direct Upstash Redis REST aliases. No extra Python package required.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Aliases also accepted: MESHI_UPSTASH_REDIS_REST_URL / MESHI_UPSTASH_REDIS_REST_TOKEN

# Standard redis:// or rediss:// URL (requires: uv sync --extra redis)
MESHI_REDIS_URL=
# Alias: REDIS_URL=

# File cache directory when Redis/Upstash is not set (default: system temp/meshilens-cache).
# MESHI_CACHE_DIR=/tmp/meshilens-cache
# Set to 0/false to disable the file layer and keep memory-only caching.
# MESHI_CACHE_FILE=1
